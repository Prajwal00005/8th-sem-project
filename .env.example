# Backend (Django) Stripe configuration
# Use your real Stripe test/live keys here
STRIPE_SECRET_KEY="sk_test_xxx"          # Your Stripe secret key (server-side)
STRIPE_PUBLISHABLE_KEY="pk_test_xxx"     # Your Stripe publishable key (also exposed to frontend via settings)
STRIPE_CLIENT_ID="ca_xxx"                # Your Stripe Connect client ID

# Frontend (React) Stripe configuration
# This is used by loadStripe(...) in adminSecurityPayment.jsx
REACT_APP_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"

# Email / database examples
EMAIL_HOST_PASSWORD="your-email-password"
MY_SQL_PASSWORD="your-mysql-password"
